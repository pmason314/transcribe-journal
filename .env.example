# Configuration for transcribe-journal service

# Directory to watch for new audio files
WATCH_FOLDER=/mnt/syncthing/voice

# Transcription endpoint URL
TRANSCRIBE_URL=http://192.168.0.165:8000/transcribe

# Ollama endpoint URL (for text cleanup)
OLLAMA_URL=http://192.168.0.165:11434/api/generate

# Ollama model to use for text cleanup
OLLAMA_MODEL=gpt-oss:20b

# Directory where cleaned transcriptions will be saved
OUTPUT_FOLDER=~/transcribed_journals

# Supported audio file extensions (comma-separated)
AUDIO_EXTENSIONS=.mp3,.wav,.m4a,.ogg,.flac,.aac,.wma
