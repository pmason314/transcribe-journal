# Configuration for transcribe-journal service

# Directory to watch for new audio files
WATCH_FOLDER="/mnt/syncthing/Voice Recordings"

# Transcription endpoint URL
TRANSCRIBE_URL=http://192.168.0.165:8000/transcribe

# Ollama endpoint URL (for text cleanup)
OLLAMA_URL=http://192.168.0.165:11434/api/generate

# Ollama model to use for text cleanup
OLLAMA_MODEL=gpt-oss:20b

# Directory where cleaned transcriptions will be saved (Obsidian journal)
JOURNAL_FOLDER="/mnt/syncthing/Obsidian/Archive/Journal"

# Maximum age of audio files in days before cleanup
AUDIO_FILE_MAX_AGE_DAYS=7

# Supported audio file extensions (comma-separated)
AUDIO_EXTENSIONS=.mp3,.wav,.m4a,.ogg,.flac,.aac,.wma

# Timezone for daily note dates (default: America/Los_Angeles)
# Use standard timezone names like America/New_York, Europe/London, etc.
NOTE_TIMEZONE=America/Los_Angeles
